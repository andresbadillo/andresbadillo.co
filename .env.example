# Vite: variables must be prefixed with VITE_ to be exposed to the client.
# Get the URL and publishable key in Supabase: Project Settings > Data API.
# The publishable key is safe to use in the browser; never add the service_role key here.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxx
